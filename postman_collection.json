{
  "info": {
    "name": "BackedBase - Boilerplate API",
    "description": "Colección completa de endpoints para el boilerplate NestJS multi-tenant.\n\nVariables:\n- {{base_url}}: URL base del servidor\n- {{access_token}}: Token JWT de acceso\n- {{refresh_token}}: Token de refresco",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "role_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "permission_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "tenant_id",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health",
              "host": ["{{base_url}}"],
              "path": ["api", "health"]
            },
            "auth": {
              "type": "noauth"
            },
            "description": "Verifica el estado del servicio, conexión a BD, uptime y timestamp."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
                  "    pm.collectionVariables.set('access_token', res.access_token);",
                  "}",
                  "if (res.refresh_token) {",
                  "    pm.collectionVariables.set('refresh_token', res.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@admin.com\",\n  \"password\": \"Admin123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "auth": {
              "type": "noauth"
            },
            "description": "Inicia sesión. Guarda automáticamente access_token y refresh_token en variables."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
                  "    pm.collectionVariables.set('access_token', res.access_token);",
                  "}",
                  "if (res.refresh_token) {",
                  "    pm.collectionVariables.set('refresh_token', res.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "auth": {
              "type": "noauth"
            },
            "description": "Renueva el access_token usando el refresh_token. Guarda los nuevos tokens automáticamente."
          }
        },
        {
          "name": "Me (Perfil)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Obtiene el perfil del usuario autenticado con sus roles y permisos."
          }
        },
        {
          "name": "Sessions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/sessions",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "sessions"]
            },
            "description": "Lista las sesiones activas del usuario autenticado."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Cierra la sesión actual invalidando el refresh token."
          }
        },
        {
          "name": "Logout All Sessions",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout-all",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout-all"]
            },
            "description": "Cierra todas las sesiones activas del usuario."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@admin.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/forgot-password",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "forgot-password"]
            },
            "auth": {
              "type": "noauth"
            },
            "description": "Solicita código de recuperación de contraseña. Rate limited: 3 por minuto."
          }
        },
        {
          "name": "Verify Code",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@admin.com\",\n  \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/verify-code",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "verify-code"]
            },
            "auth": {
              "type": "noauth"
            },
            "description": "Verifica el código de recuperación. Rate limited: 5 por minuto."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@admin.com\",\n  \"code\": \"123456\",\n  \"new_password\": \"NuevaPassword123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/reset-password",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "reset-password"]
            },
            "auth": {
              "type": "noauth"
            },
            "description": "Resetea la contraseña con código verificado. Requiere: 8+ chars, mayúscula, minúscula, número, carácter especial."
          }
        }
      ]
    },
    {
