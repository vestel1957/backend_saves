generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model audit_log {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id   String?  @db.Uuid
  user_id     String?  @db.Uuid
  module      String   @db.VarChar(50)
  submodule   String?  @db.VarChar(50)
  action      String   @db.VarChar(20)
  resource_id String?  @db.Uuid
  old_data    Json?
  new_data    Json?
  ip_address  String?  @db.Inet
  user_agent  String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  tenant      tenants? @relation(fields: [tenant_id], references: [id], onUpdate: NoAction)
  user        users?   @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([action], map: "idx_audit_action")
  @@index([created_at(sort: Desc)], map: "idx_audit_created")
  @@index([tenant_id, module, submodule], map: "idx_audit_module")
  @@index([resource_id], map: "idx_audit_resource")
  @@index([tenant_id], map: "idx_audit_tenant")
  @@index([user_id], map: "idx_audit_user")
}

model login_attempts {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id      String?  @db.Uuid
  email          String   @db.VarChar(255)
  ip_address     String   @db.Inet
  user_agent     String?
  success        Boolean  @default(false)
  failure_reason String?  @db.VarChar(50)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  tenant         tenants? @relation(fields: [tenant_id], references: [id], onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_login_created")
  @@index([email], map: "idx_login_email")
  @@index([ip_address], map: "idx_login_ip")
  @@index([tenant_id], map: "idx_login_tenant")
}

model password_history {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id         String   @db.Uuid
  password_hash   String
  changed_at      DateTime @default(now()) @db.Timestamptz(6)
  changed_by      String?  @db.Uuid
  changed_by_user users?   @relation("password_changed_by", fields: [changed_by], references: [id], onUpdate: NoAction)
  user            users    @relation("password_owner", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([changed_at(sort: Desc)], map: "idx_password_changed")
  @@index([user_id], map: "idx_password_user")
}

model permissions {
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id        String             @db.Uuid
  module           String             @db.VarChar(50)
  submodule        String             @db.VarChar(50)
  action           String             @db.VarChar(20)
  description      String?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  tenant           tenants            @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  role_permissions role_permissions[]
  user_permissions user_permissions[]

  @@unique([tenant_id, module, submodule, action])
  @@index([action], map: "idx_permissions_action")
  @@index([tenant_id, module], map: "idx_permissions_module")
  @@index([tenant_id, module, submodule], map: "idx_permissions_submodule")
  @@index([tenant_id], map: "idx_permissions_tenant")
}

model role_permissions {
  role_id       String      @db.Uuid
  permission_id String      @db.Uuid
  granted_at    DateTime    @default(now()) @db.Timestamptz(6)
  granted_by    String?     @db.Uuid
  permission    permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  role          roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([role_id, permission_id])
  @@index([permission_id], map: "idx_role_permissions_perm")
  @@index([role_id], map: "idx_role_permissions_role")
}

model roles {
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id        String             @db.Uuid
  name             String             @db.VarChar(50)
  description      String?
  is_active        Boolean            @default(true)
  is_system        Boolean            @default(false)
  parent_role_id   String?            @db.Uuid
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  role_permissions role_permissions[]
  parent_role      roles?             @relation("role_hierarchy", fields: [parent_role_id], references: [id], onUpdate: NoAction)
  child_roles      roles[]            @relation("role_hierarchy")
  tenant           tenants            @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user_roles       user_roles[]

  @@unique([tenant_id, name])
  @@index([tenant_id, is_active], map: "idx_roles_active")
  @@index([parent_role_id], map: "idx_roles_parent")
  @@index([tenant_id], map: "idx_roles_tenant")
}

model tenants {
  id             String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name           String           @db.VarChar(100)
  slug           String           @unique @db.VarChar(100)
  logo_url       String?
  domain         String?          @db.VarChar(255)
  is_active      Boolean          @default(true)
  settings       Json?            @default("{}")
  max_users      Int?             @default(50)
  plan           String?          @default("basic") @db.VarChar(30)
  contact_email  String?          @db.VarChar(255)
  contact_phone  String?          @db.VarChar(30)
  address        String?
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  updated_at     DateTime         @default(now()) @db.Timestamptz(6)
  audit_logs     audit_log[]
  login_attempts login_attempts[]
  permissions    permissions[]
  roles          roles[]
  sessions       user_sessions[]
  users          users[]
  areas          areas[]
  sedes          sedes[]

  @@index([is_active], map: "idx_tenants_active")
  @@index([plan], map: "idx_tenants_plan")
  @@index([slug], map: "idx_tenants_slug")
}

model areas {
  id         String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id  String       @db.Uuid
  name       String       @db.VarChar(100)
  is_active  Boolean      @default(true)
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  tenant     tenants      @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user_sedes user_sedes[]
  users      users[]

  @@unique([tenant_id, name])
  @@index([tenant_id], map: "idx_areas_tenant")
}

model sedes {
  id         String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id  String       @db.Uuid
  name       String       @db.VarChar(100)
  is_active  Boolean      @default(true)
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  tenant     tenants      @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user_sedes user_sedes[]

  @@unique([tenant_id, name])
  @@index([tenant_id], map: "idx_sedes_tenant")
}

model user_roles {
  user_id          String    @db.Uuid
  role_id          String    @db.Uuid
  assigned_at      DateTime  @default(now()) @db.Timestamptz(6)
  assigned_by      String?   @db.Uuid
  expires_at       DateTime? @db.Timestamptz(6)
  assigned_by_user users?    @relation("role_assigned_by", fields: [assigned_by], references: [id], onUpdate: NoAction)
  role             roles     @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user             users     @relation("user_roles", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, role_id])
  @@index([role_id], map: "idx_user_roles_role")
  @@index([user_id], map: "idx_user_roles_user")
}

model user_sedes {
  user_id     String   @db.Uuid
  sede_id     String   @db.Uuid
  area_id     String?  @db.Uuid
  assigned_at DateTime @default(now()) @db.Timestamptz(6)
  user        users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sede        sedes    @relation(fields: [sede_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  area        areas?   @relation(fields: [area_id], references: [id], onUpdate: NoAction)

  @@id([user_id, sede_id])
  @@index([user_id], map: "idx_user_sedes_user")
  @@index([sede_id], map: "idx_user_sedes_sede")
  @@index([area_id], map: "idx_user_sedes_area")
}

model user_sessions {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String   @db.Uuid
  tenant_id  String?  @db.Uuid
  token_hash String   @unique
  ip_address String?  @db.Inet
  user_agent String?
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  tenant     tenants? @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_sessions_expires")
  @@index([tenant_id], map: "idx_sessions_tenant")
  @@index([token_hash], map: "idx_sessions_token")
  @@index([user_id], map: "idx_sessions_user")
}

model users {
  id                   String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenant_id            String?                @db.Uuid
  email                String                 @unique @db.VarChar(255)
  username             String                 @unique @db.VarChar(100)
  password_hash        String
  first_name           String?                @db.VarChar(100)
  last_name            String?                @db.VarChar(100)
  avatar_url           String?
  document_number      String?                @db.VarChar(30)
  document_type        String?                @default("CC") @db.VarChar(10)
  hire_date            DateTime?              @db.Date
  blood_type           String?                @db.VarChar(5)
  eps                  String?                @db.VarChar(100)
  pension_fund         String?                @db.VarChar(100)
  address              String?
  city                 String?                @db.VarChar(100)
  department           String?                @db.VarChar(100)
  country              String?                @default("Colombia") @db.VarChar(100)
  phone                String?                @db.VarChar(30)
  area_id              String?                @db.Uuid
  signature_url        String?
  is_active            Boolean                @default(true)
  is_verified          Boolean                @default(false)
  is_super_admin       Boolean                @default(false)
  last_login_at        DateTime?              @db.Timestamptz(6)
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  audit_logs           audit_log[]
  passwords_changed    password_history[]     @relation("password_changed_by")
  password_history     password_history[]     @relation("password_owner")
  reset_codes          password_reset_codes[]
  roles_assigned       user_roles[]           @relation("role_assigned_by")
  user_roles           user_roles[]           @relation("user_roles")
  sessions             user_sessions[]
  user_sedes           user_sedes[]
  tenant               tenants?               @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  area                 areas?                 @relation(fields: [area_id], references: [id], onUpdate: NoAction)
  user_permissions     user_permissions[]     @relation("user_permissions")
  permissions_granted  user_permissions[]     @relation("permission_granted_by")

  @@index([tenant_id, is_active], map: "idx_users_active")
  @@index([email], map: "idx_users_email")
  @@index([tenant_id], map: "idx_users_tenant")
  @@index([username], map: "idx_users_username")
  @@index([area_id], map: "idx_users_area")
  @@index([document_number], map: "idx_users_document")
}

model user_permissions {
  user_id         String      @db.Uuid
  permission_id   String      @db.Uuid
  granted_at      DateTime    @default(now()) @db.Timestamptz(6)
  granted_by      String?     @db.Uuid
  granted_by_user users?      @relation("permission_granted_by", fields: [granted_by], references: [id], onUpdate: NoAction)
  permission      permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user            users       @relation("user_permissions", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, permission_id])
  @@index([permission_id], map: "idx_user_permissions_perm")
  @@index([user_id], map: "idx_user_permissions_user")
}

model password_reset_codes {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id     String   @db.Uuid
  email       String   @db.VarChar(255)
  code        String   @db.VarChar(6)
  is_verified Boolean  @default(false)
  attempts    Int      @default(0)
  expires_at  DateTime @db.Timestamptz(6)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  user        users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([email], map: "idx_reset_email")
  @@index([email, code], map: "idx_reset_code")
  @@index([expires_at], map: "idx_reset_expires")
}